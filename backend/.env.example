APP_NAME=Travel Planning Assistant
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

LLM_PROVIDER=dashscope
LLM_MODEL=travel-planner-v1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1200

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_AUDIO_MODEL=qwen-audio-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v4

ASR_PROVIDER=aliyun_nls
ALIYUN_NLS_APP_KEY=
ALIYUN_NLS_TOKEN=
ALIYUN_NLS_URL=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_NLS_REGION=cn-shanghai

DEFAULT_CITY=杭州
DEFAULT_TRIP_DAYS=3

TENCENT_MAP_API_KEY=
TENCENT_MAP_BASE_URL=https://apis.map.qq.com
TENCENT_MAP_PLACE_SEARCH_PATH=/ws/place/v1/search
TENCENT_MAP_GEOCODER_PATH=/ws/geocoder/v1/
TENCENT_MAP_DIRECTION_PATH_PREFIX=/ws/direction/v1
TENCENT_MAP_WEATHER_PATH=/ws/weather/v1/
CTRIP_API_KEY=
CTRIP_BASE_URL=
SEARCH_API_KEY=
SEARCH_BASE_URL=
WEATHER_API_KEY=
WEATHER_BASE_URL=https://apis.map.qq.com
JUSTONEAPI_TOKEN=
JUSTONEAPI_BASE_URL=https://api.justoneapi.com
JUSTONEAPI_XIAOHONGSHU_SEARCH_NOTE_PATH=/api/xiaohongshu/search-note/v4

USE_REDIS_MEMORY=true
REDIS_URL=redis://127.0.0.1:6379/0
CONVERSATION_HISTORY_LIMIT=20
CONVERSATION_MEMORY_TTL_SECONDS=86400
USER_PROFILE_TTL_SECONDS=604800

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
